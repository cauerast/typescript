{
    "compilerOptions": {
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "rootDir": "src",
        "outDir": "build",

        "types": ["node"],

        // "noUnusedLocals": true,
        // "noUnusedParameters": true,
        // "noEmitOnError": true
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}